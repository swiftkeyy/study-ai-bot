BOT_TOKEN=PASTE_TELEGRAM_BOT_TOKEN_HERE
ADMIN_ID=123456789

DB_PATH=bot.db

# AI keys
GEMINI_API_KEY=PASTE_GEMINI_KEY_HERE
GROQ_API_KEY=PASTE_GROQ_KEY_HERE
OPENROUTER_API_KEY=PASTE_OPENROUTER_KEY_HERE
DEEPAI_API_KEY=PASTE_DEEPAI_KEY_HERE

# Models (можно оставить как есть)
GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_MODEL=openrouter/free

# Defaults
DEFAULT_FREE_LIMIT=3
DEFAULT_FREE_IMAGE_LIMIT=1
DEFAULT_STARS_PRICE_3=59
DEFAULT_STARS_PRICE_7=99
DEFAULT_STARS_PRICE_30=199
DEFAULT_RUB_PRICE_3=99
DEFAULT_RUB_PRICE_7=199
DEFAULT_RUB_PRICE_30=499

# YooKassa
YOOKASSA_SHOP_ID=PASTE_YOOKASSA_SHOP_ID_HERE
YOOKASSA_SECRET_KEY=PASTE_YOOKASSA_SECRET_KEY_HERE
YOOKASSA_RETURN_URL=https://t.me/YourBotUsername
YOOKASSA_WEBHOOK_HOST=0.0.0.0
YOOKASSA_WEBHOOK_PORT=8080

# Logs
LOG_LEVEL=INFO
LOG_FILE=bot.log
