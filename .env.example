BOT_TOKEN=PASTE_TELEGRAM_BOT_TOKEN_HERE
ADMIN_ID=123456789

DB_PATH=/app/data/bot.db

# AI keys
GEMINI_API_KEY=PASTE_GEMINI_KEY_HERE
GROQ_API_KEY=PASTE_GROQ_KEY_HERE
OPENROUTER_API_KEY=PASTE_OPENROUTER_KEY_HERE

# Models (можно оставить как есть)
GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_MODEL=openrouter/free

# Defaults
DEFAULT_FREE_LIMIT=3
DEFAULT_STARS_PRICE_3=59
DEFAULT_STARS_PRICE_7=99
DEFAULT_STARS_PRICE_30=199
DEFAULT_RUB_PRICE_3=99
DEFAULT_RUB_PRICE_7=199
DEFAULT_RUB_PRICE_30=499

# CryptoBot / Crypto Pay
C# Robokassa
ROBOKASSA_MERCHANT_LOGIN=your_shop_login
ROBOKASSA_PASSWORD1=your_password_1
ROBOKASSA_PASSWORD2=your_password_2
ROBOKASSA_HASH_ALGO=md5
ROBOKASSA_IS_TEST=1

# Внутренний сервер в контейнере
ROBOKASSA_WEBHOOK_HOST=0.0.0.0
ROBOKASSA_WEBHOOK_PORT=8081

# Обычно менять не нужно
ROBOKASSA_PAYMENT_URL=https://auth.robokassa.ru/Merchant/Index.aspx


# Logs
LOG_LEVEL=INFO
LOG_FILE=/app/data/bot.log
